ANYLLM_MASTER_KEY=replace-with-long-random-string
# Docker mode: pin any-llm gateway image to a known-good digest.
ANYLLM_GATEWAY_IMAGE=ghcr.io/mozilla-ai/any-llm/gateway@sha256:64541d4b67b8edd8c1ba6ee3c3af61b0bbaf758c3dd97ade484a900a803caf2a
# Local mode: any-llm SDK git ref used by scripts/install-local.sh.
ANYLLM_SDK_REF=2008c49806abfb5e891ebf60c65cb6daec9120c8

# Optional providers (set the ones you want to use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GEMINI_API_KEY=

# Local cost router settings
ROUTER_SHARED_KEY=
ROUTER_DEFAULT_USER=openclaw-local
OPENCLAW_MODEL=claw-auto-cheap
ROUTER_PORT=4000
ANYLLM_PORT=8000
PRICING_CACHE_TTL_SEC=60
REQUEST_TIMEOUT_SEC=240

# Local (no Docker) mode
# When running without Docker, set ANYLLM_BASE_URL to your local gateway:
# ANYLLM_BASE_URL=http://localhost:8000
