models:
  claw-auto-cheap:
    description: "Tier-first + cheapest-in-tier routing (recommended default)"
    default_output_tokens: 700
    default_tier: MEDIUM
    fallback_tiers_on_failure: true
    tier_fallback_order: [COMPLEX, REASONING, SIMPLE]
    tiers:
      SIMPLE:
        - model: gemini:gemini-2.5-flash
          input_price_per_million: 0.30
          output_price_per_million: 2.50
        - model: anthropic:claude-haiku-4-5
          input_price_per_million: 1.00
          output_price_per_million: 5.00
      MEDIUM:
        - model: gemini:gemini-2.5-flash
          input_price_per_million: 0.30
          output_price_per_million: 2.50
        - model: anthropic:claude-sonnet-4-6
          input_price_per_million: 3.00
          output_price_per_million: 15.00
      COMPLEX:
        - model: openai:gpt-5
          input_price_per_million: 2.00
          output_price_per_million: 8.00
        - model: anthropic:claude-sonnet-4-6
          input_price_per_million: 3.00
          output_price_per_million: 15.00
      REASONING:
        - model: openai:o3-mini
          input_price_per_million: 1.10
          output_price_per_million: 4.40
        - model: gemini:gemini-2.5-pro
          input_price_per_million: 1.25
          output_price_per_million: 10.00

  claw-cost-only:
    description: "Pure cost-first alias (no tier classification)"
    default_output_tokens: 1200
    candidates:
      - model: gemini:gemini-2.5-flash
        input_price_per_million: 0.30
        output_price_per_million: 2.50
      - model: anthropic:claude-haiku-4-5
        input_price_per_million: 1.00
        output_price_per_million: 5.00
